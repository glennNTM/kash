NODE_ENV=development
PORT=8000

# ── Base de données
# Dev local  → Postgres local (postgresql://USER:PASS@HOST:5432/DB)
# Prod       → Supabase pooler 6543 (DATABASE_URL) + direct 5432 (DIRECT_URL)
DATABASE_URL=
DIRECT_URL=

# ── Better Auth 
# Générer : openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8000

# ── Arcjet 
ARCJET_KEY=

# ── CORS 
FRONTEND_URL=http://localhost:5173

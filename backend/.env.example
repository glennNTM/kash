NODE_ENV=development
PORT=8000

# ── Base de données
# Dev local   → Postgres local (postgresql://USER:PASS@HOST:5432/DB)
# Prod (Neon) → DATABASE_URL = endpoint pooled (host avec -pooler), runtime
#               DIRECT_URL   = endpoint direct (sans -pooler), migrations drizzle-kit
#               Ajouter ?sslmode=require aux deux URLs Neon.
DATABASE_URL=
DIRECT_URL=

# ── Better Auth
# Générer : openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8000

# ── Google OAuth (optionnel : laisser vide pour désactiver le provider)
# Redirect URI à whitelister dans Google Cloud Console :
#   http://localhost:8000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Arcjet
ARCJET_KEY=

# ── CORS 
FRONTEND_URL=http://localhost:5173
